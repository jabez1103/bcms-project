DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=bcms
DB_SSL=false
# Optional CA cert for managed MySQL (Aiven). Use either PEM text with \n, or base64-encoded PEM.
DB_SSL_CA=
DB_CONNECT_TIMEOUT_MS=10000

# Must be at least 32 characters in production
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated allowed origins for auth/cors checks
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Optional tuning values
SYSTEM_LOG_MAX=500
MAX_NOTIFICATIONS_PER_USER=100

# Web push notifications (required only if push features are used)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bisu.edu.ph

# Upload safety: keep false for cloud deployments unless you intentionally
# store uploads on local disk in production.
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION=false
